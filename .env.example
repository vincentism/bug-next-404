# 生产自托管必填：Server Action 加密密钥，需与构建时一致，避免 "Failed to find Server Action"。
# 生成：openssl rand -base64 32；详见 docs/PRODUCTION_ENV_AND_SERVER_ACTIONS.md
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=''

# pnpm ec2 上传静态资源到 Cloudflare R2 时使用（可选，不配置则跳过 R2 上传）
# 在 Cloudflare 控制台 R2 → 管理 R2 API 令牌 → 创建 S3 兼容凭据
# R2_ACCOUNT_ID=''
# R2_ACCESS_KEY_ID=''
# R2_SECRET_ACCESS_KEY=''
# R2_BUCKET_NAME='web-static'
