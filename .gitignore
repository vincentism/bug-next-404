# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
.windsurfrules

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel
*idea
# typescript
*.tsbuildinfo
next-env.d.ts

# clerk configuration (can include secrets)
/.clerk/

# stripe
.stripe/

# editor
.vscode/*
.idea/*

# docs (internal documentation, not for version control)
# Note: docs/ is gitignored but files can still be created/edited locally
# scripts
docs/*.md
docs/*.json
!docs/README.md

# Sentry Config File
.env.sentry-build-plugin
.claude/worktrees/
.env*.local

# claude / cursor editor
.claude/
.cursor/

# macOS Finder duplicates (e.g. "file 2.tsx", "file 3.tsx")
*\ [0-9].*
*\ [0-9][0-9].*

# misc generated docs
AGENTS.md
